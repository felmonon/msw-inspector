{
  "name": "msw-inspector",
  "version": "0.1.0",
  "description": "Find gaps between your MSW handlers and your actual API usage.",
  "license": "MIT",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/felmonon/msw-inspector.git"
  },
  "homepage": "https://github.com/felmonon/msw-inspector#readme",
  "bugs": {
    "url": "https://github.com/felmonon/msw-inspector/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "msw-inspector": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "action.yml"
  ],
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts src/github-action/index.ts --format cjs --dts --out-dir dist --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "npm run typecheck && npm run test",
    "prepack": "npm run build"
  },
  "keywords": [
    "msw",
    "mock-service-worker",
    "test-coverage",
    "api-mocking",
    "developer-tooling",
    "github-action"
  ],
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.1",
    "commander": "^14.0.1",
    "fast-glob": "^3.3.3",
    "path-to-regexp": "^8.3.0",
    "picocolors": "^1.1.1",
    "ts-morph": "^27.0.2"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18"
  }
}
